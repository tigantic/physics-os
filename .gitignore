# .gitignore for Project HyperTensor

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# VS Code
.vscode/
*.code-workspace

# PyCharm
.idea/

# OS files
.DS_Store
Thumbs.db

# Results directory (keep README only)
results/*
!results/README.md

# Large data files
*.h5
*.hdf5
*.npy
*.npz
*.pt
*.pth
!proofs/*.json

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
*.swp
*~

# Secrets (never commit)
.secrets
*.key
*.pem
credentials.json
*_keys.json
!*_keys.json.example
cuda-keyring_1.1-1_all.deb

# Rust build artifacts
glass-cockpit/target/
target/
zk_targets/zk-email-verify
crypto_data/
noaa_24h_raw/
real_data/*.bin
real_data/*.nc
*.zip
Clawdbot/
clawdbot-main/
target/
noaa_24h_raw/
lean_yang_mills/
products/fluidelite-zk/fluidelite.img
FRONTIER/07_GENOMICS/data/clinvar.vcf.gz
FRONTIER/07_GENOMICS/data/*.vcf.gz

# External submodule directories (managed separately)
tornado-circuits/
vendor/circom-ecdsa/
vendor/semaphore-circuits/
worldcoin-circuits/
worldcoin-id/
yang_mills_unified_proof/.lake/packages/mathlib/
zk_targets/
media/
video/output/concat.txt
demo_output/

# Windows Zone.Identifier metadata
*:Zone.Identifier

# Ephemeral summaries
.execution_summary.txt
.github_validation_summary.txt

# SvelteKit project — override Python lib/ rule for src/lib/
!sovereign-ui/src/lib/
!sovereign-ui/src/lib/**
