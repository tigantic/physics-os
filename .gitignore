# .gitignore for The Physics OS

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# VS Code
.vscode/
*.code-workspace

# PyCharm
.idea/

# OS files
.DS_Store
Thumbs.db

# Results directory (keep README only)
results/*
!results/README.md

# Large data files
*.h5
*.hdf5
*.npy
*.npz
*.pt
*.pth
!proofs/*.json

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
*.swp
*~
nohup.out

# Backup files
*.bak

# Secrets (never commit)
.secrets
*.key
*.pem
credentials.json
*_keys.json
*_key.json
gevulot_key.json
!*_keys.json.example
cuda-keyring_1.1-1_all.deb

# Rust build artifacts
target/
zk_targets/zk-email-verify
real_data/*.bin
real_data/*.nc
*.zip

# Products build artifacts
products/fluidelite-zk/fluidelite.img

# External submodule directories (managed separately)
yang_mills_unified_proof/.lake/packages/mathlib/

# Windows Zone.Identifier metadata
*:Zone.Identifier
*_Zone.Identifier

# Ephemeral summaries
.execution_summary.txt
.github_validation_summary.txt

# SvelteKit project — override Python lib/ rule for src/lib/
!sovereign-ui/src/lib/
!sovereign-ui/src/lib/**

# Rank Atlas experiment data (large binary / JSON output)
data/atlas_*.parquet
data/rank_atlas_*.parquet

# Benchmark result directories (in experiments/)
experiments/atlas_results*/

# ── Large data files (>100 MB, exceeds GitHub limit) ──────────────────────────
data/real_data/goes18_reconstructed.bin
experiments/frontier/07_GENOMICS/data/clinvar.vcf.gz

pdb_cache/
data/pdb_cache/

# ── Former submodule directories (gitlinks removed, dirs remain on disk) ──────
archive/vendor/circom-ecdsa/
archive/vendor/semaphore-circuits/
proofs/yang_mills/unified/.lake/
proofs/zk_circuits/tornado/
proofs/zk_circuits/worldcoin_circuits/
proofs/zk_circuits/worldcoin_id/
proofs/zk_targets/

# Generated simulation output
scenario_results.json
scenario_output/
output_*_sweep.log
output_full_sweep.log
output_*.log
