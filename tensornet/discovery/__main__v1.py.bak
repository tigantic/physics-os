"""
AUTONOMOUS DISCOVERY ENGINE — Command Line Interface

Usage:
    python -m tensornet.discovery discover <data_file> [options]
    python -m tensornet.discovery stream <data_source> [options]
    python -m tensornet.discovery verify <attestation_file>
    python -m tensornet.discovery info

Commands:
    discover    Run discovery on a data file
    stream      Stream discovery from a data source
    verify      Verify an attestation file
    info        Show engine information

Options:
    --domain        Target domain (defi, physics, geometry, full)
    --severity      Minimum severity to report (info, low, medium, high, critical)
    --output        Output file for findings (JSON)
    --attestation   Directory for attestation files
    --no-attest     Disable attestation generation
    --verbose       Verbose output

Example:
    python -m tensornet.discovery discover data.pt --domain defi --output findings.json
    python -m tensornet.discovery stream ws://localhost:8080 --domain defi
    python -m tensornet.discovery verify attestations/abc123.json

Copyright (c) 2026 Tigantic Holdings LLC. All Rights Reserved.
"""

import argparse
import json
import sys
from datetime import datetime
from pathlib import Path
from typing import Optional

import torch


def main() -> int:
    """Main entry point for CLI."""
    parser = argparse.ArgumentParser(
        prog="tensornet.discovery",
        description="Autonomous Discovery Engine CLI",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    
    subparsers = parser.add_subparsers(dest="command", help="Command to run")
    
    # Discover command
    discover_parser = subparsers.add_parser(
        "discover",
        help="Run discovery on a data file",
    )
    discover_parser.add_argument(
        "data_file",
        type=str,
        help="Path to data file (.pt, .npy, .json)",
    )
    discover_parser.add_argument(
        "--domain",
        type=str,
        default="full",
        choices=["defi", "physics", "geometry", "full"],
        help="Target domain",
    )
    discover_parser.add_argument(
        "--severity",
        type=str,
        default="info",
        choices=["info", "low", "medium", "high", "critical"],
        help="Minimum severity to report",
    )
    discover_parser.add_argument(
        "--output",
        type=str,
        default=None,
        help="Output file for findings (JSON)",
    )
    discover_parser.add_argument(
        "--attestation",
        type=str,
        default="attestations",
        help="Directory for attestation files",
    )
    discover_parser.add_argument(
        "--no-attest",
        action="store_true",
        help="Disable attestation generation",
    )
    discover_parser.add_argument(
        "--verbose",
        "-v",
        action="store_true",
        help="Verbose output",
    )
    
    # Verify command
    verify_parser = subparsers.add_parser(
        "verify",
        help="Verify an attestation file",
    )
    verify_parser.add_argument(
        "attestation_file",
        type=str,
        help="Path to attestation JSON file",
    )
    
    # Info command
    info_parser = subparsers.add_parser(
        "info",
        help="Show engine information",
    )
    info_parser.add_argument(
        "--domain",
        type=str,
        default="full",
        help="Domain to show info for",
    )
    
    args = parser.parse_args()
    
    if args.command is None:
        parser.print_help()
        return 1
    
    if args.command == "discover":
        return cmd_discover(args)
    elif args.command == "verify":
        return cmd_verify(args)
    elif args.command == "info":
        return cmd_info(args)
    else:
        parser.print_help()
        return 1


def cmd_discover(args: argparse.Namespace) -> int:
    """Run discovery command."""
    from tensornet.discovery import DiscoveryEngine, DiscoveryConfig, Severity
    
    # Parse severity
    severity_map = {
        "info": Severity.INFO,
        "low": Severity.LOW,
        "medium": Severity.MEDIUM,
        "high": Severity.HIGH,
        "critical": Severity.CRITICAL,
    }
    severity = severity_map.get(args.severity, Severity.INFO)
    
    # Load data
    data_path = Path(args.data_file)
    if not data_path.exists():
        print(f"Error: Data file not found: {data_path}", file=sys.stderr)
        return 1
    
    if args.verbose:
        print(f"Loading data from {data_path}...")
    
    try:
        if data_path.suffix == ".pt":
            data = torch.load(data_path)
        elif data_path.suffix == ".npy":
            import numpy as np
            data = torch.from_numpy(np.load(data_path))
        elif data_path.suffix == ".json":
            with open(data_path) as f:
                data = json.load(f)
        else:
            print(f"Error: Unsupported file format: {data_path.suffix}", file=sys.stderr)
            return 1
    except Exception as e:
        print(f"Error loading data: {e}", file=sys.stderr)
        return 1
    
    # Create config
    config = DiscoveryConfig(
        domain=args.domain,
        severity_threshold=severity,
        enable_attestation=not args.no_attest,
        attestation_dir=args.attestation,
    )
    
    # Create engine
    if args.verbose:
        print(f"Creating DiscoveryEngine with domain={args.domain}...")
    
    engine = DiscoveryEngine(domain=args.domain, config=config)
    
    # Run discovery
    if args.verbose:
        print("Running discovery...")
    
    run = engine.discover(data)
    
    # Output results
    print(f"\n{'='*60}")
    print(f"DISCOVERY COMPLETE")
    print(f"{'='*60}")
    print(f"Run ID: {run.run_id}")
    print(f"Duration: {run.duration_seconds():.3f}s")
    print(f"Findings: {len(run.findings)}")
    
    if run.findings:
        print(f"\n--- Findings Summary ---")
        summary = run.findings.summary()
        print(f"By severity: {summary['by_severity']}")
        print(f"By type: {summary['by_type']}")
        print(f"By primitive: {summary['by_primitive']}")
        
        print(f"\n--- Top Findings ---")
        for finding in run.findings.sort_by_severity()[:10]:
            print(f"  [{finding.severity.name}] {finding.summary}")
    
    if run.attestation:
        print(f"\n--- Attestation ---")
        print(f"Hash: {run.attestation.attestation_hash}")
        print(f"Saved to: {args.attestation}/{run.run_id}.json")
    
    # Save findings if output specified
    if args.output:
        output_path = Path(args.output)
        output_path.parent.mkdir(parents=True, exist_ok=True)
        
        with open(output_path, "w") as f:
            f.write(run.findings.to_json())
        
        print(f"\nFindings saved to: {output_path}")
    
    return 0


def cmd_verify(args: argparse.Namespace) -> int:
    """Verify attestation command."""
    from tensornet.discovery import DiscoveryAttestation
    
    attestation_path = Path(args.attestation_file)
    if not attestation_path.exists():
        print(f"Error: Attestation file not found: {attestation_path}", file=sys.stderr)
        return 1
    
    try:
        with open(attestation_path) as f:
            attestation = DiscoveryAttestation.from_json(f.read())
    except Exception as e:
        print(f"Error loading attestation: {e}", file=sys.stderr)
        return 1
    
    # Verify
    is_valid = attestation.verify()
    
    print(f"\n{'='*60}")
    print(f"ATTESTATION VERIFICATION")
    print(f"{'='*60}")
    print(f"Run ID: {attestation.run_id}")
    print(f"Timestamp: {attestation.timestamp}")
    print(f"Input Hash: {attestation.input_hash[:16]}...")
    print(f"Findings Hash: {attestation.findings_hash[:16]}...")
    print(f"Pipeline Hash: {attestation.pipeline_hash[:16]}...")
    print(f"Attestation Hash: {attestation.attestation_hash}")
    print(f"\nVerification: {'✓ VALID' if is_valid else '✗ INVALID'}")
    
    return 0 if is_valid else 1


def cmd_info(args: argparse.Namespace) -> int:
    """Show engine info command."""
    from tensornet.discovery import DiscoveryEngine
    
    engine = DiscoveryEngine(domain=args.domain)
    
    print(f"\n{'='*60}")
    print(f"AUTONOMOUS DISCOVERY ENGINE")
    print(f"{'='*60}")
    print(f"Version: 1.0.0")
    print(f"Domain: {args.domain}")
    print(f"Pipeline: {engine.pipeline.name}")
    print(f"\nStages:")
    for i, stage in enumerate(engine.pipeline.stage_names):
        print(f"  {i+1}. {stage}")
    
    print(f"\nGenesis Primitives:")
    print(f"  - OT: Optimal Transport (Layer 20)")
    print(f"  - SGW: Spectral Graph Wavelets (Layer 21)")
    print(f"  - RMT: Random Matrix Theory (Layer 22)")
    print(f"  - RKHS: Kernel Methods (Layer 24)")
    print(f"  - PH: Persistent Homology (Layer 25)")
    print(f"  - GA: Geometric Algebra (Layer 26)")
    
    print(f"\nFinding Types:")
    print(f"  - Anomaly: Distribution drifts, spectral outliers")
    print(f"  - Invariant: Conservation laws, symmetries")
    print(f"  - Bottleneck: Resource constraints, phase transitions")
    print(f"  - Prediction: Emergent patterns, failure modes")
    
    return 0


if __name__ == "__main__":
    sys.exit(main())
