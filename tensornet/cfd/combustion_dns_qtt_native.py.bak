"""
QTT-Native 1D Reacting-Flow DNS Solver
========================================

Premixed H2-air flame propagation using the full QTT/Triton engine.
Every field (T, Y_k, rho, u) lives as a PackedQTT.  Derivatives use
combined stencil MPOs.  Variable-coefficient transport uses QTT Hadamard
products.  Chemistry source terms are built via TCI (Tensor Cross
Interpolation) so the solver NEVER calls qtt_to_dense or materializes
full dense arrays in the solver loop.

Architecture:
    Transport step:  MPO derivatives -> property fields as QTT via TCI ->
                     Hadamard products for variable coefficients ->
                     adaptive rSVD truncation.  **Zero dense.**
    Chemistry step:  Integration result built as QTT via TCI -- the
                     pointwise ODE integrator runs ONLY at TCI pivot
                     points (or all N for small problems, handled by
                     the TCI dispatch).  **No explicit decompression.**
    BCs:             Windowed QTT operations -- multiply by interior
                     window QTT + add BC QTT.  **Zero dense.**
    Diagnostics:     Sparse QTT evaluation at sample points for dt
                     computation; full eval only for user-facing plots.

Physical target: S_L ~ 2-3 m/s for lean-to-stoichiometric H2-air at 1 atm.

QTT Rules Enforced:
    - QTT is native: all fields live as PackedQTT at all times
    - SVD = rSVD: via torch.svd_lowrank (GPU-only Halko-Martinsson-Tropp)
    - Adaptive rank: tolerance-driven, not fixed
    - No decompression in solver loop: qtt_eval_batch for point access
    - No dense arrays in solver loop: TCI builds QTTs directly

Author: HyperTensor Team
"""

from __future__ import annotations

import math
from dataclasses import dataclass
from typing import Any, Callable, Dict, List, Optional, Tuple

import torch
from torch import Tensor

from tensornet.cfd.nd_shift_mpo import make_nd_shift_mpo
from tensornet.cfd.qtt_triton_native import (
    PackedMPO,
    PackedQTT,
    adaptive_truncate,
    build_derivative_mpo,
    identity_mpo_cores,
    mpo_add_cores,
    triton_mpo_apply,
    triton_qtt_add,
    triton_qtt_hadamard,
    triton_qtt_inner,
    triton_qtt_norm,
    triton_qtt_scale,
)
from tensornet.cfd.qtt_tci import qtt_from_function

# =====================================================================
# Chemical Mechanism Data
# =====================================================================

_H2 = 0
_O2 = 1
_H2O = 2
_H = 3
_O = 4
_OH = 5
_N_SPECIES = 6

_MW = torch.tensor(
    [2.016e-3, 32.0e-3, 18.015e-3, 1.008e-3, 16.0e-3, 17.008e-3],
    dtype=torch.float64,
)

_NASA_HIGH: Dict[int, Tuple[float, ...]] = {
    _H2: (2.99142, 7.0006e-4, -5.633e-8, -9.231e-12, 1.582e-15, -835.0, -1.355),
    _O2: (3.66096, 6.5637e-4, -1.411e-7, 2.058e-11, -1.299e-15, -1216.0, 3.416),
    _H2O: (2.67704, 2.9735e-3, -7.737e-7, 9.443e-11, -4.269e-15, -29886.0, 6.883),
    _H: (2.50000, 0.0, 0.0, 0.0, 0.0, 25474.0, -0.460),
    _O: (2.54206, -2.755e-5, -3.102e-9, 4.551e-12, -4.368e-16, 29230.0, 4.921),
    _OH: (2.88273, 1.0139e-3, -2.276e-7, 2.175e-11, -5.126e-16, 3886.0, 5.595),
}

_NASA_LOW: Dict[int, Tuple[float, ...]] = {
    _H2: (3.29812, 8.249e-4, -8.143e-7, -9.475e-11, 4.134e-13, -1013.0, -3.294),
    _O2: (3.21294, 1.1275e-3, -5.756e-7, 1.314e-10, -8.768e-15, -1005.0, 6.034),
    _H2O: (3.38684, 3.4749e-3, -6.355e-6, 6.969e-9, -2.507e-12, -30208.0, 2.590),
    _H: (2.50000, 0.0, 0.0, 0.0, 0.0, 25474.0, -0.460),
    _O: (2.94643, -1.6382e-3, 2.421e-6, -1.602e-9, 3.891e-13, 29148.0, 2.964),
    _OH: (3.63727, -1.8510e-4, 3.426e-6, -3.286e-9, 1.121e-12, 3615.0, 1.359),
}

_HF298 = torch.tensor(
    [0.0, 0.0, -241826.0, 217999.0, 249175.0, 38987.0],
    dtype=torch.float64,
)

_R_UNIV = 8.31446
_W_N2 = 28.014e-3

# N₂ NASA-7 thermodynamic coefficients (not a tracked species but needed for cp)
_N2_NASA_HIGH = (2.95258, 1.3969e-3, -4.926e-7, 7.860e-11, -4.608e-15, -923.9, 5.872)
_N2_NASA_LOW = (3.53101, -1.2366e-4, -5.030e-7, 2.435e-9, -1.409e-12, -1047.0, 2.967)


@dataclass
class ReactionMechanism:
    """Reduced H2-air mechanism with correct thermodynamics."""
    n_species: int = _N_SPECIES
    n_reactions: int = 3
    species_names: Tuple[str, ...] = ("H2", "O2", "H2O", "H", "O", "OH")
    mw: Tensor = None  # type: ignore[assignment]

    def __post_init__(self) -> None:
        if self.mw is None:
            self.mw = _MW.clone()


def hydrogen_air_9species() -> ReactionMechanism:
    """Return reduced H2-air mechanism (backward-compat name)."""
    return ReactionMechanism()


# =====================================================================
# Thermodynamic Properties
# =====================================================================

def _cp_species_R(T: Tensor) -> Tensor:
    """cp_k / R for each species.  (N, n_species)."""
    N = T.shape[0]
    cp = torch.zeros(N, _N_SPECIES, dtype=T.dtype, device=T.device)
    high_mask = T >= 1000.0
    for k in range(_N_SPECIES):
        ah = _NASA_HIGH[k]
        al = _NASA_LOW[k]
        cp_high = ah[0] + ah[1] * T + ah[2] * T**2 + ah[3] * T**3 + ah[4] * T**4
        cp_low = al[0] + al[1] * T + al[2] * T**2 + al[3] * T**3 + al[4] * T**4
        cp[:, k] = torch.where(high_mask, cp_high, cp_low)
    return cp


def mixture_cp(T: Tensor, Y: Tensor, mw: Tensor) -> Tensor:
    """Mixture cp [J/(kg*K)].  Includes N₂ dilutant (Y_N2 = 1 - sum(Y_k))."""
    cp_over_R = _cp_species_R(T)  # (N, n_species)
    mw_dev = mw.to(device=T.device, dtype=T.dtype)
    cp_mass = cp_over_R * _R_UNIV / mw_dev.unsqueeze(0)  # (N, n_species)
    cp_tracked = (Y * cp_mass).sum(dim=1)  # J/(kg·K) from tracked species

    # N₂ contribution: Y_N2 = 1 - sum(Y_k), cp_N2 from NASA polynomials
    Y_N2 = (1.0 - Y.sum(dim=1)).clamp(min=0.0)
    high_mask = T >= 1000.0
    ah = _N2_NASA_HIGH
    al = _N2_NASA_LOW
    cp_N2_R_high = ah[0] + ah[1] * T + ah[2] * T**2 + ah[3] * T**3 + ah[4] * T**4
    cp_N2_R_low = al[0] + al[1] * T + al[2] * T**2 + al[3] * T**3 + al[4] * T**4
    cp_N2_R = torch.where(high_mask, cp_N2_R_high, cp_N2_R_low)
    cp_N2_mass = cp_N2_R * _R_UNIV / _W_N2  # J/(kg·K)

    return cp_tracked + Y_N2 * cp_N2_mass


# =====================================================================
# Transport Properties
# =====================================================================

def mixture_thermal_conductivity(T: Tensor) -> Tensor:
    """lambda [W/(m*K)].  Eucken for N2-dominated."""
    return 2.58e-2 * (T.clamp(min=200.0) / 300.0) ** 0.7


def species_diffusivity(T: Tensor, p: float) -> Tensor:
    """D_k [m2/s] into N2.  Chapman-Enskog.  (N, n_sp)."""
    D_ref = torch.tensor(
        [7.7e-5, 2.1e-5, 2.5e-5, 8.5e-5, 2.2e-5, 2.3e-5],
        dtype=T.dtype, device=T.device,
    )
    return D_ref.unsqueeze(0) * (T.clamp(min=200.0) / 300.0).unsqueeze(1) ** 1.75 * (101325.0 / p)


def thermal_diffusivity(T: Tensor, Y: Tensor, rho: Tensor, mw: Tensor) -> Tensor:
    """alpha = lambda / (rho * cp) [m2/s]."""
    lam = mixture_thermal_conductivity(T)
    cp = mixture_cp(T, Y, mw)
    return lam / (rho * cp)


# =====================================================================
# Chemical Kinetics
# =====================================================================

@dataclass
class _ArrheniusRate:
    A: float
    beta: float
    Ea: float

_REACTIONS = [
    _ArrheniusRate(A=4.0e7, beta=0.0, Ea=80000.0),   # Calibrated: ZFK gives S_L ≈ 2 m/s at phi=1
    _ArrheniusRate(A=5.06e4, beta=2.67, Ea=26300.0),  # O + H2 -> H + OH (chain branching)
    _ArrheniusRate(A=3.55e15, beta=-0.41, Ea=69500.0), # H + O2 -> O + OH (chain branching)
]


def _rate_constants(T: Tensor, thickening_factor: float = 1.0) -> Tuple[Tensor, Tensor, Tensor]:
    """Arrhenius rate constants, optionally divided by thickening factor F.

    Thickened Flame Model (TFM): dividing omega by F while multiplying
    diffusivities by F preserves S_L but widens the flame thickness by F,
    enabling DNS on coarser grids.
    """
    T_safe = T.clamp(min=200.0, max=6000.0)
    inv_RT = 1.0 / (_R_UNIV * T_safe)
    inv_F = 1.0 / thickening_factor
    k1 = _REACTIONS[0].A * inv_F * torch.exp(-_REACTIONS[0].Ea * inv_RT)
    k2 = _REACTIONS[1].A * inv_F * T_safe ** _REACTIONS[1].beta * torch.exp(-_REACTIONS[1].Ea * inv_RT)
    k3 = _REACTIONS[2].A * inv_F * T_safe ** _REACTIONS[2].beta * torch.exp(-_REACTIONS[2].Ea * inv_RT)
    return k1, k2, k3


def species_production_rates(
    T: Tensor, Y: Tensor, rho: Tensor, mw: Tensor,
    thickening_factor: float = 1.0,
) -> Tensor:
    """omega_k [kg/(m3*s)].  (N, n_sp).  Optionally thinned by 1/F."""
    mw_dev = mw.to(device=T.device, dtype=T.dtype)
    C = (rho.unsqueeze(1) * Y / mw_dev.unsqueeze(0)).clamp(min=0.0)
    k1, k2, k3 = _rate_constants(T, thickening_factor)
    r1 = k1 * C[:, _H2] * C[:, _O2]
    r2 = k2 * C[:, _H2] * C[:, _O]
    r3 = k3 * C[:, _H] * C[:, _O2]
    omega = torch.zeros_like(C)
    omega[:, _H2] += -2.0 * r1 - 1.0 * r2
    omega[:, _O2] += -1.0 * r1 - 1.0 * r3
    omega[:, _H2O] += 2.0 * r1
    omega[:, _H] += 1.0 * r2 - 1.0 * r3
    omega[:, _O] += -1.0 * r2 + 1.0 * r3
    omega[:, _OH] += 1.0 * r2 + 1.0 * r3
    return omega * mw_dev.unsqueeze(0)


def heat_release_rate(
    T: Tensor, Y: Tensor, rho: Tensor, mw: Tensor,
) -> Tensor:
    """q [W/m3] = -sum(omega_k * hf_k / W_k)."""
    omega = species_production_rates(T, Y, rho, mw)
    mw_dev = mw.to(device=T.device, dtype=T.dtype)
    hf = _HF298.to(device=T.device, dtype=T.dtype)
    return -(omega / mw_dev.unsqueeze(0) * hf.unsqueeze(0)).sum(dim=1)


# =====================================================================
# QTT Point Evaluation
# =====================================================================
#
# Replaces qtt_to_dense_1d.  Evaluates at SELECTED points only.
# Cost: O(B * L * r^2)  vs  O(2^L * r^2) for full decompress.

def qtt_eval_batch(qtt: PackedQTT, indices: Tensor) -> Tensor:
    """
    Evaluate QTT at a batch of grid points without full decompression.

    Contracts core chain at each index via binary decomposition.

    Args:
        qtt:     PackedQTT field
        indices: Linear grid indices, shape (B,), long

    Returns:
        Values, shape (B,)
    """
    cores = qtt.unpack()
    n_bits = len(cores)
    B = indices.shape[0]
    device = cores[0].device
    dtype = cores[0].dtype

    if B == 0:
        return torch.empty(0, device=device, dtype=dtype)

    bit0 = (indices >> (n_bits - 1)) & 1
    c0 = cores[0]  # (1, 2, r1)
    v = c0[:, bit0, :].permute(1, 0, 2).squeeze(1)  # (B, r1)

    for k in range(1, n_bits):
        bit_k = (indices >> (n_bits - 1 - k)) & 1
        ck = cores[k]  # (rl, 2, rr)
        slices = ck[:, bit_k, :].permute(1, 0, 2)  # (B, rl, rr)
        v = torch.bmm(v.unsqueeze(1), slices).squeeze(1)  # (B, rr)

    return v.squeeze(1)  # (B,)


def qtt_eval_point(qtt: PackedQTT, idx: int) -> float:
    """Single-point QTT evaluation.  O(L * r^2)."""
    cores = qtt.unpack()
    n_bits = len(cores)
    v = cores[0][:, (idx >> (n_bits - 1)) & 1, :]
    for k in range(1, n_bits):
        v = v @ cores[k][:, (idx >> (n_bits - 1 - k)) & 1, :]
    return v.item()


# =====================================================================
# QTT from Pointwise Physics
# =====================================================================

def qtt_from_pointwise(
    physics_func: Callable[[Dict[str, Tensor]], Tensor],
    ref_qtts: Dict[str, PackedQTT],
    n_bits: int,
    max_rank: int = 64,
    tol: float = 1e-6,
    device: str = "cuda",
) -> PackedQTT:
    """
    Build QTT of a nonlinear pointwise function of existing QTT fields.

    physics_func receives dict of field values (B, float64) and returns (B,) float32.
    Internally uses qtt_eval_batch + qtt_from_function (TCI dispatch).
    """
    def _eval_at_indices(indices: Tensor) -> Tensor:
        vals: Dict[str, Tensor] = {}
        for name, qtt in ref_qtts.items():
            vals[name] = qtt_eval_batch(qtt, indices).to(torch.float64)
        return physics_func(vals).to(torch.float32)

    cores, _ = qtt_from_function(
        _eval_at_indices, n_bits, max_rank, tol, device=device,
    )
    return PackedQTT(cores)


# =====================================================================
# 1D Combined Stencil MPOs
# =====================================================================

def build_1d_derivative_mpo(
    n_bits: int, dx: float, device: torch.device,
    dtype: torch.dtype = torch.float32,
) -> PackedMPO:
    """(S_fwd - S_bwd)/(2*dx) = central difference first derivative.

    Note: make_nd_shift_mpo direction convention is:
        direction=+1 → S+f[i] = f[i-1]  (backward/left shift)
        direction=-1 → S-f[i] = f[i+1]  (forward/right shift)
    So df/dx ≈ (f[i+1] - f[i-1])/(2dx) = (S_minus - S_plus)/(2dx).
    """
    s_back = make_nd_shift_mpo(n_bits, num_dims=1, axis_idx=0, direction=+1, device=device, dtype=dtype)
    s_fwd = make_nd_shift_mpo(n_bits, num_dims=1, axis_idx=0, direction=-1, device=device, dtype=dtype)
    return PackedMPO(build_derivative_mpo(s_fwd, s_back, dx))


def build_1d_laplacian_mpo(
    n_bits: int, dx: float, device: torch.device,
    dtype: torch.dtype = torch.float32,
) -> PackedMPO:
    """(S+ + S- - 2I)/dx^2.  Zero cancellation."""
    sp = make_nd_shift_mpo(n_bits, num_dims=1, axis_idx=0, direction=+1, device=device, dtype=dtype)
    sm = make_nd_shift_mpo(n_bits, num_dims=1, axis_idx=0, direction=-1, device=device, dtype=dtype)
    inv_dx2 = 1.0 / (dx * dx)
    combined = mpo_add_cores(sp, sm, inv_dx2, inv_dx2)
    I_cores = identity_mpo_cores(n_bits, D=2, device=device, dtype=dtype)
    combined = mpo_add_cores(combined, I_cores, 1.0, -2.0 * inv_dx2)
    return PackedMPO(combined)


# =====================================================================
# Solver State
# =====================================================================

@dataclass
class CombustionState:
    """All fields as PackedQTT.  Zero dense."""
    T: PackedQTT
    Y: List[PackedQTT]
    rho: PackedQTT
    u: PackedQTT
    t: float


# =====================================================================
# QTT-Native Combustion DNS Solver
# =====================================================================

class CombustionDNSSolver:
    """
    1D premixed flame DNS -- all fields in QTT form.

    Strang splitting: Chem(dt/2) -> Transport(dt) -> Chem(dt/2)
    Transport: combined stencil MPOs + Hadamard products (zero dense)
    Chemistry: TCI-based result construction (zero explicit decompress)
    BCs: QTT windowing (zero dense)
    """

    def __init__(
        self,
        mechanism: ReactionMechanism,
        nx: int = 256,
        L: float = 0.02,
        cfl: float = 0.3,
        tol: float = 1e-6,
        rank_cap: int = 64,
        n_chem_sub: int = 10,
        p_atm: float = 101325.0,
    ) -> None:
        self.mech = mechanism
        self.p = p_atm
        self.n_bits = int(math.log2(nx))
        if 2**self.n_bits != nx:
            raise ValueError(f"nx must be power of 2, got {nx}")
        self.nx = nx
        self.L = L
        self.dx = L / nx
        self.tol = tol
        self.rank_cap = rank_cap
        self.cfl = cfl
        self.n_chem_sub = n_chem_sub
        self.device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
        self.dtype = torch.float32
        self._dev_str = str(self.device)

        # Thickened Flame Model (TFM) factor.
        # H₂-air thermal flame thickness ≈ 0.5 mm.  With dx = L/nx:
        #   nx=256, L=0.02 → dx=78μm → ~6 cells across flame → resolvable.
        # Only activate TFM when dx > thermal_width / n_cells_min.
        _delta_thermal = 5.0e-4  # m (H₂-air thermal flame half-width)
        _n_cells_min = 4
        self.thickening_factor: float = max(1.0, _n_cells_min * self.dx / _delta_thermal)

        self.ddx_mpo = build_1d_derivative_mpo(self.n_bits, self.dx, self.device, self.dtype)
        self.d2dx2_mpo = build_1d_laplacian_mpo(self.n_bits, self.dx, self.device, self.dtype)
        self.mw = mechanism.mw.to(device=self.device, dtype=torch.float64)

        self._window_qtt: Optional[PackedQTT] = None
        self._bc_qtts: Dict[str, PackedQTT] = {}
        self._bc_n_buf: int = 5
        self._bc_T_left: float = 300.0
        self._bc_T_right: float = 300.0
        self._bc_rho_left: float = 1.16
        self._bc_rho_right: float = 0.11

    # -----------------------------------------------------------------
    # Initialization
    # -----------------------------------------------------------------

    def premixed_flame_init(
        self,
        T_u: float = 300.0,
        T_b: float = 2200.0,
        phi: float = 1.0,
        p: float = 101325.0,
    ) -> CombustionState:
        """Initialize 1D premixed flame via TCI.  Flame at x = L/2.

        Uses a preheat-zone initialization:
        - Temperature: smooth tanh from T_u to T_ad with width delta_T
        - Species: sharper tanh from Y_u to Y_b with width delta_Y < delta_T
        - The offset between thermal and species profiles creates a preheat
          zone where T has risen but fuel hasn't yet burned.  This
          disequilibrium drives the flame.
        - T_ad computed self-consistently from enthalpy balance.
        - Density from ideal gas law.
        """
        self.p = p
        n_bits = self.n_bits
        nx = self.nx
        L = self.L
        device = self.device
        dev = self._dev_str

        W_H2, W_O2, W_H2O = 2.016e-3, 32.0e-3, 18.015e-3
        denom_u = phi * 2.0 * W_H2 + W_O2 + 3.76 * _W_N2
        Y_H2_u = phi * 2.0 * W_H2 / denom_u
        Y_O2_u = W_O2 / denom_u

        if phi <= 1.0:
            Y_H2_b, Y_O2_b = 0.0, (1.0 - phi) * W_O2 / denom_u
            Y_H2O_b = phi * 2.0 * W_H2O / denom_u
        else:
            Y_O2_b = 0.0
            Y_H2O_b = 2.0 * W_H2O / denom_u
            Y_H2_b = (phi - 1.0) * 2.0 * W_H2 / denom_u

        # Flame widths: thermal > species → creates preheat zone
        delta_T = max(5e-4, 4.0 * self.dx)   # thermal width (half-width of tanh)
        delta_Y = delta_T * 0.4               # species width (sharper: reaction zone)
        x_flame = L / 2.0

        Y_u = torch.tensor([Y_H2_u, Y_O2_u, 0.0, 0.0, 0.0, 0.0], dtype=torch.float64, device=device)
        Y_b = torch.tensor([Y_H2_b, Y_O2_b, Y_H2O_b, 0.0, 0.0, 0.0], dtype=torch.float64, device=device)
        mw64 = self.mw.to(dtype=torch.float64, device=device)
        hf64 = _HF298.to(device=device, dtype=torch.float64)

        def _mean_mw(Yk: Tensor) -> float:
            Y_N2_val = 1.0 - Yk.sum().item()
            return 1.0 / ((Yk / mw64).sum().item() + Y_N2_val / _W_N2)

        # Compute adiabatic flame temperature T_ad from enthalpy balance
        cp_u = mixture_cp(
            torch.tensor([T_u], dtype=torch.float64, device=device),
            Y_u.unsqueeze(0), mw64,
        ).item()
        h_chem_u = (Y_u * hf64 / mw64).sum().item()
        h_total_u = cp_u * T_u + h_chem_u

        T_ad = float(T_b)
        for _ in range(50):
            cp_b = mixture_cp(
                torch.tensor([T_ad], dtype=torch.float64, device=device),
                Y_b.unsqueeze(0), mw64,
            ).item()
            h_chem_b = (Y_b * hf64 / mw64).sum().item()
            T_ad_new = (h_total_u - h_chem_b) / max(cp_b, 100.0)
            if abs(T_ad_new - T_ad) < 0.1:
                break
            T_ad = 0.7 * T_ad + 0.3 * T_ad_new
        T_ad = max(T_ad, T_u + 100.0)

        rho_u = p / (_R_UNIV / _mean_mw(Y_u) * T_u)
        rho_b = p / (_R_UNIV / _mean_mw(Y_b) * T_ad)

        self._bc_T_left, self._bc_T_right = T_u, T_ad
        self._bc_rho_left, self._bc_rho_right = rho_u, rho_b

        dx_grid = L / nx

        def _build(func: Callable[[Tensor], Tensor]) -> PackedQTT:
            cores, _ = qtt_from_function(func, n_bits, self.rank_cap, self.tol, device=dev)
            return PackedQTT(cores)

        # Temperature: wide tanh from T_u to T_ad
        def _T_profile(idx: Tensor) -> Tensor:
            x = idx.to(torch.float64) * dx_grid
            xi = 0.5 * (1.0 + torch.tanh((x - x_flame) / delta_T))
            return (T_u + (T_ad - T_u) * xi).to(torch.float32)

        T_qtt = _build(_T_profile)

        # Species: sharper tanh from Y_u to Y_b (narrower → preheat zone)
        Y_qtt: List[PackedQTT] = []
        for k in range(_N_SPECIES):
            a, b = Y_u[k].item(), Y_b[k].item()

            def _Yk_profile(idx: Tensor, _a: float = a, _b: float = b) -> Tensor:
                x = idx.to(torch.float64) * dx_grid
                xi = 0.5 * (1.0 + torch.tanh((x - x_flame) / delta_Y))
                return (_a + (_b - _a) * xi).to(torch.float32)

            Y_qtt.append(_build(_Yk_profile))

        # Density: ideal gas law with local T and composition
        def _rho_profile(idx: Tensor) -> Tensor:
            x = idx.to(torch.float64) * dx_grid
            xi_T = 0.5 * (1.0 + torch.tanh((x - x_flame) / delta_T))
            xi_Y = 0.5 * (1.0 + torch.tanh((x - x_flame) / delta_Y))
            T_loc = T_u + (T_ad - T_u) * xi_T
            Y_loc = torch.zeros(idx.shape[0], _N_SPECIES, dtype=torch.float64, device=device)
            for k in range(_N_SPECIES):
                Y_loc[:, k] = Y_u[k].item() + (Y_b[k].item() - Y_u[k].item()) * xi_Y
            Y_N2 = (1.0 - Y_loc.sum(dim=1)).clamp(min=0.0)
            inv_W = (Y_loc / mw64.unsqueeze(0)).sum(dim=1) + Y_N2 / _W_N2
            return (p / (_R_UNIV * inv_W * T_loc)).to(torch.float32)

        rho_qtt = _build(_rho_profile)

        zero_cores = [torch.zeros(1, 2, 1, device=device, dtype=self.dtype) for _ in range(n_bits)]
        u_qtt = PackedQTT(zero_cores)

        self._build_bc_qtts(Y_u, Y_b, rho_u, rho_b, T_u, T_ad)

        return CombustionState(T=T_qtt, Y=Y_qtt, rho=rho_qtt, u=u_qtt, t=0.0)

    # -----------------------------------------------------------------
    # BC Enforcement (QTT windowing -- zero dense)
    # -----------------------------------------------------------------

    def _build_bc_qtts(
        self, Y_u: Tensor, Y_b: Tensor,
        rho_u: float, rho_b: float, T_u: float, T_b: float,
    ) -> None:
        """Pre-build window and BC QTTs for Dirichlet enforcement."""
        n_bits, nx, n_buf, dev = self.n_bits, self.nx, self._bc_n_buf, self._dev_str

        def _window(indices: Tensor) -> Tensor:
            v = torch.ones(len(indices), device=indices.device, dtype=torch.float32)
            v[indices < n_buf] = 0.0
            v[indices >= nx - n_buf] = 0.0
            return v

        w_cores, _ = qtt_from_function(_window, n_bits, 16, 1e-10, device=dev)
        self._window_qtt = PackedQTT(w_cores)

        def _make_bc(lv: float, rv: float) -> PackedQTT:
            def _f(indices: Tensor) -> Tensor:
                v = torch.zeros(len(indices), device=indices.device, dtype=torch.float32)
                v[indices < n_buf] = lv
                v[indices >= nx - n_buf] = rv
                return v
            c, _ = qtt_from_function(_f, n_bits, 16, 1e-10, device=dev)
            return PackedQTT(c)

        self._bc_qtts["T"] = _make_bc(T_u, T_b)
        self._bc_qtts["rho"] = _make_bc(rho_u, rho_b)
        for k in range(_N_SPECIES):
            self._bc_qtts[f"Y_{k}"] = _make_bc(Y_u[k].item(), Y_b[k].item())

    def _apply_bcs_qtt(self, field: PackedQTT, name: str) -> PackedQTT:
        """f_corrected = hadamard(f, window) + bc."""
        if self._window_qtt is None or name not in self._bc_qtts:
            return field
        windowed = triton_qtt_hadamard(field, self._window_qtt)
        corrected = triton_qtt_add(windowed, self._bc_qtts[name])
        return adaptive_truncate(corrected, tol=self.tol, rank_cap=self.rank_cap)

    # -----------------------------------------------------------------
    # Transport (fully QTT-native -- zero dense)
    # -----------------------------------------------------------------

    def _transport_step(self, state: CombustionState, dt: float) -> CombustionState:
        """
        dT/dt = F*alpha(x)*d2T/dx2 - u(x)*dT/dx
        dYk/dt = F*Dk(x)*d2Yk/dx2 - u(x)*dYk/dx

        All QTT: MPO derivatives, TCI property fields, Hadamard products.
        Diffusivities multiplied by thickening factor F (TFM).
        """
        tol, rc, n_bits, dev = self.tol, self.rank_cap, self.n_bits, self._dev_str
        mw, p_atm = self.mw, self.p
        F = self.thickening_factor

        # Derivatives via MPOs
        lap_T = adaptive_truncate(triton_mpo_apply(self.d2dx2_mpo, state.T), tol=tol, rank_cap=rc)
        grad_T = adaptive_truncate(triton_mpo_apply(self.ddx_mpo, state.T), tol=tol, rank_cap=rc)

        # alpha(x) as QTT via TCI -- MULTIPLIED by F
        ref_all: Dict[str, PackedQTT] = {"T": state.T, "rho": state.rho}
        for k in range(_N_SPECIES):
            ref_all[f"Y_{k}"] = state.Y[k]

        def _alpha_f(vals: Dict[str, Tensor]) -> Tensor:
            Y_loc = torch.stack([vals[f"Y_{k}"] for k in range(_N_SPECIES)], dim=1)
            return (F * thermal_diffusivity(vals["T"], Y_loc, vals["rho"], mw)).to(torch.float32)

        alpha_qtt = qtt_from_pointwise(_alpha_f, ref_all, n_bits, rc, tol, dev)

        # RHS_T = alpha*lap_T - u*grad_T
        diff_T = adaptive_truncate(triton_qtt_hadamard(alpha_qtt, lap_T), tol=tol, rank_cap=rc)
        adv_T = adaptive_truncate(triton_qtt_hadamard(state.u, grad_T), tol=tol, rank_cap=rc)
        rhs_T = adaptive_truncate(
            triton_qtt_add(diff_T, triton_qtt_scale(adv_T, -1.0)), tol=tol, rank_cap=rc,
        )
        T_new = adaptive_truncate(
            triton_qtt_add(state.T, triton_qtt_scale(rhs_T, dt)), tol=tol, rank_cap=rc,
        )

        # Species
        Y_new: List[PackedQTT] = []
        for sp in range(_N_SPECIES):
            lap_Y = adaptive_truncate(triton_mpo_apply(self.d2dx2_mpo, state.Y[sp]), tol=tol, rank_cap=rc)
            grad_Y = adaptive_truncate(triton_mpo_apply(self.ddx_mpo, state.Y[sp]), tol=tol, rank_cap=rc)

            def _Dk_f(vals: Dict[str, Tensor], _sp: int = sp) -> Tensor:
                return (F * species_diffusivity(vals["T"], p_atm)[:, _sp]).to(torch.float32)

            Dk_qtt = qtt_from_pointwise(_Dk_f, {"T": state.T}, n_bits, rc, tol, dev)

            diff_Y = adaptive_truncate(triton_qtt_hadamard(Dk_qtt, lap_Y), tol=tol, rank_cap=rc)
            adv_Y = adaptive_truncate(triton_qtt_hadamard(state.u, grad_Y), tol=tol, rank_cap=rc)
            rhs_Y = adaptive_truncate(
                triton_qtt_add(diff_Y, triton_qtt_scale(adv_Y, -1.0)), tol=tol, rank_cap=rc,
            )
            Yk_new = adaptive_truncate(
                triton_qtt_add(state.Y[sp], triton_qtt_scale(rhs_Y, dt)), tol=tol, rank_cap=rc,
            )
            Y_new.append(Yk_new)

        # BCs
        T_new = self._apply_bcs_qtt(T_new, "T")
        for k in range(_N_SPECIES):
            Y_new[k] = self._apply_bcs_qtt(Y_new[k], f"Y_{k}")

        return CombustionState(T=T_new, Y=Y_new, rho=state.rho, u=state.u, t=state.t)

    # -----------------------------------------------------------------
    # Chemistry (TCI-based -- no explicit decompression)
    # -----------------------------------------------------------------

    def _chemistry_step(self, state: CombustionState, dt: float) -> CombustionState:
        """
        Integrate chemistry ODE -> build converged result as QTT via TCI.

        The integrator runs at TCI pivot points (or all N for n_bits<=12).
        Cache ensures integration runs once for all output fields.
        """
        n_bits, rc, tol, dev = self.n_bits, self.rank_cap, self.tol, self._dev_str
        mw = self.mw
        hf = _HF298.to(device=self.device, dtype=torch.float64)
        n_sub_base, p_atm = self.n_chem_sub, self.p
        F_thick = self.thickening_factor

        T_qtt, Y_qtts, rho_qtt = state.T, state.Y, state.rho

        _cache: Dict[int, Tuple[Tensor, Tensor, Tensor]] = {}

        def _integrate(indices: Tensor) -> Tuple[Tensor, Tensor, Tensor]:
            ck = hash((indices.shape[0], indices.sum().item()))
            if ck in _cache:
                return _cache[ck]

            T_loc = qtt_eval_batch(T_qtt, indices).to(torch.float64)
            rho_loc = qtt_eval_batch(rho_qtt, indices).to(torch.float64)
            Y_loc = torch.stack(
                [qtt_eval_batch(Y_qtts[k], indices).to(torch.float64) for k in range(_N_SPECIES)],
                dim=1,
            )

            cp_init = mixture_cp(T_loc, Y_loc, mw)
            h_chem_init = (Y_loc * hf.unsqueeze(0) / mw.unsqueeze(0)).sum(dim=1)
            h_total = cp_init * T_loc + h_chem_init

            omega_init = species_production_rates(T_loc, Y_loc, rho_loc, mw, F_thick)
            active = (Y_loc > 1e-6) & (omega_init.abs() > 1e-10)
            n_sub = n_sub_base
            if active.any():
                tau = (
                    Y_loc[active] * rho_loc.unsqueeze(1).expand_as(Y_loc)[active]
                ) / omega_init[active].abs()
                n_sub = max(n_sub_base, int(math.ceil(dt / (0.5 * tau.min().item()))))
            n_sub = min(n_sub, 5000)
            dt_sub = dt / n_sub

            for _ in range(n_sub):
                omega = species_production_rates(T_loc, Y_loc, rho_loc, mw, F_thick)
                Y_loc = (Y_loc + dt_sub * omega / rho_loc.clamp(min=0.01).unsqueeze(1)).clamp(min=0.0)
                Y_sum = Y_loc.sum(dim=1, keepdim=True)
                Y_loc = Y_loc - (Y_sum - 1.0).clamp(min=0.0) * Y_loc / (Y_sum + 1e-30)
                h_chem = (Y_loc * hf.unsqueeze(0) / mw.unsqueeze(0)).sum(dim=1)
                cp = mixture_cp(T_loc, Y_loc, mw)
                T_loc = ((h_total - h_chem) / cp.clamp(min=100.0)).clamp(200.0, 4000.0)
                Y_N2 = (1.0 - Y_loc.sum(dim=1)).clamp(min=0.0)
                inv_W = (Y_loc / mw.unsqueeze(0)).sum(dim=1) + Y_N2 / _W_N2
                rho_loc = p_atm / (_R_UNIV * inv_W.clamp(min=1e-10) * T_loc)

            _cache[ck] = (T_loc, Y_loc, rho_loc)
            return T_loc, Y_loc, rho_loc

        T_cores, _ = qtt_from_function(
            lambda i: _integrate(i)[0].to(torch.float32), n_bits, rc, tol, device=dev,
        )
        T_new = PackedQTT(T_cores)

        Y_new: List[PackedQTT] = []
        for k in range(_N_SPECIES):
            def _yk(i: Tensor, _k: int = k) -> Tensor:
                return _integrate(i)[1][:, _k].to(torch.float32)
            c, _ = qtt_from_function(_yk, n_bits, rc, tol, device=dev)
            Y_new.append(PackedQTT(c))

        rho_cores, _ = qtt_from_function(
            lambda i: _integrate(i)[2].to(torch.float32), n_bits, rc, tol, device=dev,
        )
        rho_new = PackedQTT(rho_cores)

        T_new = self._apply_bcs_qtt(T_new, "T")
        for k in range(_N_SPECIES):
            Y_new[k] = self._apply_bcs_qtt(Y_new[k], f"Y_{k}")
        rho_new = self._apply_bcs_qtt(rho_new, "rho")

        return CombustionState(T=T_new, Y=Y_new, rho=rho_new, u=state.u, t=state.t)

    # -----------------------------------------------------------------
    # Time Step (sparse QTT eval -- no dense)
    # -----------------------------------------------------------------

    def _compute_dt(self, state: CombustionState) -> float:
        """CFL + diffusion stability from sparse sample points."""
        N = self.nx
        n_s = min(64, N)
        idx = torch.linspace(0, N - 1, n_s, device=self.device).long()

        T_s = qtt_eval_batch(state.T, idx).to(torch.float64)
        u_s = qtt_eval_batch(state.u, idx).to(torch.float64)
        rho_s = qtt_eval_batch(state.rho, idx).to(torch.float64)
        Y_s = torch.stack(
            [qtt_eval_batch(state.Y[k], idx).to(torch.float64) for k in range(_N_SPECIES)], dim=1,
        )

        u_eff = max(u_s.abs().max().item(), 3.0)
        dt_cfl = self.cfl * self.dx / u_eff

        alpha_max = thermal_diffusivity(T_s, Y_s, rho_s, self.mw).max().item()
        alpha_max *= self.thickening_factor  # TFM: effective diffusivity is F * alpha
        dt_diff = 0.25 * self.dx**2 / max(alpha_max, 1e-20)

        return max(min(dt_cfl, dt_diff), 1e-12)

    # -----------------------------------------------------------------
    # Time Integration
    # -----------------------------------------------------------------

    def evolve(self, state: CombustionState, t_end: float) -> CombustionState:
        """Strang splitting: Chem(dt/2) -> Transport(dt) -> Chem(dt/2)."""
        current = CombustionState(
            T=state.T, Y=list(state.Y), rho=state.rho, u=state.u, t=state.t,
        )
        t_rem = t_end

        while t_rem > 1e-15:
            dt = min(self._compute_dt(current), t_rem)
            current = self._chemistry_step(current, dt / 2.0)
            current = self._transport_step(current, dt)
            current = self._chemistry_step(current, dt / 2.0)
            current.t += dt
            t_rem -= dt

        return current

    # -----------------------------------------------------------------
    # Diagnostics (user-facing, not in solver loop)
    # -----------------------------------------------------------------

    def max_heat_release(self, state: CombustionState) -> float:
        """Peak heat release [W/m3]."""
        idx = torch.arange(self.nx, device=self.device)
        T_v = qtt_eval_batch(state.T, idx).to(torch.float64)
        rho_v = qtt_eval_batch(state.rho, idx).to(torch.float64)
        Y_v = torch.stack([qtt_eval_batch(state.Y[k], idx).to(torch.float64) for k in range(_N_SPECIES)], dim=1)
        return float(heat_release_rate(T_v, Y_v, rho_v, self.mw).max().item())

    def flame_speed(self, state: CombustionState) -> float:
        """Consumption S_L = (1/rho_u) * integral(|omega_fuel| dx)."""
        idx = torch.arange(self.nx, device=self.device)
        T_v = qtt_eval_batch(state.T, idx).to(torch.float64)
        rho_v = qtt_eval_batch(state.rho, idx).to(torch.float64)
        Y_v = torch.stack([qtt_eval_batch(state.Y[k], idx).to(torch.float64) for k in range(_N_SPECIES)], dim=1)
        omega = species_production_rates(T_v, Y_v, rho_v, self.mw)
        n_u = max(1, self.nx // 10)
        rho_u = rho_v[:n_u].mean().item()
        return omega[:, _H2].abs().sum().item() * self.dx / max(rho_u, 0.01)

    def get_temperature_profile(self, state: CombustionState) -> Tensor:
        """T at all points (for plotting -- not in solver loop)."""
        return qtt_eval_batch(state.T, torch.arange(self.nx, device=self.device)).to(torch.float64)

    def get_species_profiles(self, state: CombustionState) -> Tensor:
        """Y_k at all points (N, n_sp).  For plotting."""
        idx = torch.arange(self.nx, device=self.device)
        return torch.stack([qtt_eval_batch(state.Y[k], idx).to(torch.float64) for k in range(_N_SPECIES)], dim=1)

    def get_max_ranks(self, state: CombustionState) -> Dict[str, int]:
        """Max rank per field."""
        r: Dict[str, int] = {"T": max(state.T.rr.tolist()), "rho": max(state.rho.rr.tolist()), "u": max(state.u.rr.tolist())}
        for k in range(_N_SPECIES):
            r[f"Y_{k}"] = max(state.Y[k].rr.tolist())
        return r
