# ─────────────────────────────────────────────────────────────────────
# The Physics OS Facial Plastics Platform — Container Image
# ─────────────────────────────────────────────────────────────────────
# Build:
#   podman build -f products/facial_plastics/Containerfile -t physics-os-facial-plastics .
#   docker build -f products/facial_plastics/Containerfile -t physics-os-facial-plastics .
#
# Run (production via gunicorn):
#   docker run --rm -p 8420:8420 physics-os-facial-plastics
#
# Run (dev — stdlib server):
#   docker run --rm -p 8420:8420 --entrypoint python physics-os-facial-plastics \
#     -m products.facial_plastics.cli serve --host 0.0.0.0
#
# Run (CLI):
#   docker run --rm --entrypoint python physics-os-facial-plastics \
#     -m products.facial_plastics.cli info
# ─────────────────────────────────────────────────────────────────────

FROM python:3.12-slim AS base

LABEL maintainer="The Physics OS <team@tigantic.com>"
LABEL description="Ontic Facial Plastics — Surgical Simulation Platform"

# Prevent Python from writing .pyc files and enable unbuffered output
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# System dependencies (minimal — numpy has pre-built wheels)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# ── Install Python dependencies ──────────────────────────────────
WORKDIR /app

COPY products/facial_plastics/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# ── Copy product source ──────────────────────────────────────────
# Copy only the products/facial_plastics package and supporting files
COPY products/__init__.py /app/products/__init__.py
COPY products/facial_plastics/ /app/products/facial_plastics/

# Ensure products package is importable
ENV PYTHONPATH=/app

# ── Data volume ───────────────────────────────────────────────────
RUN mkdir -p /data /etc/fp
VOLUME ["/data"]
ENV PHYSICS_OS_DATA_ROOT=/data

# ── Network ───────────────────────────────────────────────────────
EXPOSE 8420

# ── Health check ──────────────────────────────────────────────────
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8420/health', timeout=5)" || exit 1

# ── Default entrypoint: gunicorn with WSGI adapter ───────────────
ENTRYPOINT ["gunicorn", \
    "products.facial_plastics.ui.wsgi:create_app()", \
    "--config", "products/facial_plastics/gunicorn.conf.py"]
CMD []
