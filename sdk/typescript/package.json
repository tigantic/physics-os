{
  "name": "@fluidelite/verify",
  "version": "1.0.0",
  "description": "TPC Certificate Verification SDK — verify Trustless Physics Certificates locally and on-chain",
  "author": "Bradly Biron Baker Adams <brad@tigantic.com>",
  "license": "SEE LICENSE IN LICENSE",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist/", "README.md"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0"
  },
