# HyperTensor Server Environment Configuration
# Copy to .env and customize for your environment

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins for CORS
# Default: localhost only (secure default)
HYPERTENSOR_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# For development with all origins (NOT recommended for production):
# HYPERTENSOR_CORS_ORIGINS=*

# For production, specify exact origins:
# HYPERTENSOR_CORS_ORIGINS=https://myapp.example.com,https://api.example.com

# =============================================================================
# Server Configuration
# =============================================================================
# Host to bind the server to
# HYPERTENSOR_HOST=0.0.0.0

# Port to run the server on
# HYPERTENSOR_PORT=8000

# Number of worker processes (for uvicorn)
# HYPERTENSOR_WORKERS=4

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# HYPERTENSOR_LOG_LEVEL=INFO

# Log file path (optional, logs to stdout by default)
# HYPERTENSOR_LOG_FILE=/var/log/hypertensor/server.log

# =============================================================================
# Security
# =============================================================================
# Secret key for signing (generate a strong random key for production)
# HYPERTENSOR_SECRET_KEY=your-secret-key-here

# API key for authentication (optional)
# HYPERTENSOR_API_KEY=your-api-key-here

# =============================================================================
# Performance
# =============================================================================
# Maximum field memory in bytes (default: 1GB)
# HYPERTENSOR_MAX_MEMORY=1073741824

# Maximum number of concurrent fields
# HYPERTENSOR_MAX_FIELDS=100

# Request timeout in seconds
# HYPERTENSOR_TIMEOUT=30
