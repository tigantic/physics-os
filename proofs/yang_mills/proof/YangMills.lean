/-- The Hilbert space for a lattice of L sites -/
def LatticeHilbertSpace : (L : ℕ) → Type* := L → ℂ →L[ℂ] ℂ

/-- The fundamental representation of SU(2) -/
def SU2Rep : Type* := Fin 2 → ℂ

/-- A lattice gauge field configuration -/
def GaugeField : (L : ℕ) → Type* := Fin L → Fin 4 → SU2Rep

/-- The Wilson plaquette U_μν(x) = U_μ(x) U_ν(x+μ) U_μ†(x+ν) U_ν†(x) -/
def WilsonPlaquette : (U : GaugeField L) → (site : Fin L) → (μ ν : Fin 4) → ℂ := fun U site μ ν => sorry

/-- Electric field energy: (g²/2) Σ E² -/
def ElectricEnergy : (g : ℝ) → (E : GaugeField L → ℂ) → ℝ := fun g E => (g^2 / 2) * sorry

/-- Magnetic field energy: (1/g²) Σ (1 - Re Tr U_□) -/
def MagneticEnergy : (g : ℝ) → (U : GaugeField L) → ℝ := fun g U => (1 / g^2) * sorry

/-- The full Yang-Mills Hamiltonian H = H_E + H_B -/
def YangMillsHamiltonian : (L : ℕ) → (g : ℝ) → (GaugeField L → ℂ) → (GaugeField L → ℝ) := fun L g state => ElectricEnergy g sorry + MagneticEnergy g sorry

/-- The spectrum of a linear operator -/
def Spectrum : (H : (X → ℂ) → (X → ℂ)) → Set ℝ := sorry

/-- The ground state energy E₀ = inf(spectrum(H)) -/
def GroundStateEnergy : (H : (X → ℂ) → (X → ℂ)) → ℝ := sInf (Spectrum H)

/-- The mass gap Δ = E₁ - E₀ -/
def MassGap : (H : (X → ℂ) → (X → ℂ)) → ℝ := sInf {E ∈ Spectrum H | E > GroundStateEnergy H} - GroundStateEnergy H

/-- The infinite volume limit exists in the Hausdorff metric on spectra -/
def InfiniteVolumeLimitExists : (H : ℕ → (X → ℂ) → (X → ℝ)) → Prop := ∃ H_∞, ∀ ε > 0, ∃ L₀, ∀ L ≥ L₀, dist (Spectrum (H L)) (Spectrum H_∞) < ε

