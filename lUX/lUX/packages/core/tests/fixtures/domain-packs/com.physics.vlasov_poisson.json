{
  "id": "com.physics.vlasov_poisson",
  "version": "1.0.0",
  "metrics": {
    "conservation_residual": {
      "label": "Conservation Residual",
      "symbol_latex": "r",
      "unit": "dimensionless",
      "format": "scientific",
      "precision": 3,
      "validity_range": [0, 1]
    },
    "l2_drift": {
      "label": "L2 Drift",
      "symbol_latex": "\\|\\Delta\\|_2",
      "unit": "dimensionless",
      "format": "scientific",
      "precision": 3,
      "validity_range": [0, 1]
    },
    "particle_number": {
      "label": "Particle Number",
      "symbol_latex": "N",
      "unit": "dimensionless",
      "format": "fixed",
      "precision": 4
    },
    "energy": {
      "label": "Total Energy",
      "symbol_latex": "E",
      "unit": "J",
      "format": "scientific",
      "precision": 4
    },
    "entropy": {
      "label": "Entropy",
      "symbol_latex": "S",
      "unit": "J/K",
      "format": "scientific",
      "precision": 4
    },
    "divB_residual": {
      "label": "\u2207\u00b7B Residual",
      "symbol_latex": "\\nabla \\cdot \\mathbf{B}",
      "unit": "T/m",
      "format": "scientific",
      "precision": 4,
      "validity_range": [0, 1e-10]
    }
  },
  "gate_packs": {
    "audit": {
      "label": "Audit",
      "manifest_ref": "audit-v1",
      "highlight_metrics": ["conservation_residual", "l2_drift", "particle_number", "energy"]
    }
  },
  "viewers": [
    {
      "when": {
        "artifact_type": "time_series"
      },
      "component": "TimeSeriesViewer",
      "default_config": {},
      "priority": 10
    },
    {
      "when": {
        "artifact_type": "log"
      },
      "component": "LogViewer",
      "default_config": {},
      "priority": 10
    },
    {
      "when": {
        "artifact_type": "table"
      },
      "component": "TableViewer",
      "default_config": {},
      "priority": 10
    }
  ],
  "templates": {
    "executive_summary_metric_ids": ["conservation_residual", "l2_drift", "particle_number", "energy"],
    "publication_sections": ["Abstract", "Methods", "Results", "Integrity"],
    "citation_format": "bibtex"
  }
}
