{
  "id": "com.physics.large_scale_linear_algebra",
  "version": "1.0.0",
  "metrics": {
    "conservation_residual": {
      "label": "Conservation Residual",
      "symbol_latex": "r",
      "unit": "dimensionless",
      "format": "scientific",
      "precision": 3,
      "validity_range": [
        0,
        1
      ]
    },
    "l2_drift": {
      "label": "L2 Drift",
      "symbol_latex": "\\|\\Delta\\|_2",
      "unit": "dimensionless",
      "format": "scientific",
      "precision": 3,
      "validity_range": [
        0,
        1
      ]
    },
    "objective_value": {
      "label": "Objective Value",
      "symbol_latex": "f(x)",
      "unit": "dimensionless",
      "format": "scientific",
      "precision": 6
    }
  },
  "gate_packs": {
    "audit": {
      "label": "Audit",
      "manifest_ref": "audit-v1",
      "highlight_metrics": [
        "conservation_residual",
        "l2_drift",
        "objective_value"
      ]
    }
  },
  "viewers": [
    {
      "when": {
        "artifact_type": "time_series"
      },
      "component": "TimeSeriesViewer",
      "default_config": {},
      "priority": 10
    },
    {
      "when": {
        "artifact_type": "log"
      },
      "component": "LogViewer",
      "default_config": {},
      "priority": 10
    },
    {
      "when": {
        "artifact_type": "table"
      },
      "component": "TableViewer",
      "default_config": {},
      "priority": 10
    }
  ],
  "templates": {
    "executive_summary_metric_ids": [
      "conservation_residual",
      "l2_drift",
      "objective_value"
    ],
    "publication_sections": [
      "Abstract",
      "Methods",
      "Results",
      "Integrity"
    ],
    "citation_format": "bibtex"
  }
}
