a"},"rawMetadata":"{\"compiler\":{\"version\":\"0.8.33+commit.64118f21\"},\"language\":\"Solidity\",\"output\":{\"abi\":[{\"inputs\":[],\"name\":\"InvalidProof\",\"type\":\"error\"},{\"inputs\":[],\"name\":\"InvalidPublicInput\",\"type\":\"error\"},{\"inputs\":[],\"name\":\"PairingFailed\",\"type\":\"error\"},{\"inputs\":[],\"name\":\"maxTreeDepth\",\"outputs\":[{\"internalType\":\"uint8\",\"name\":\"\",\"type\":\"uint8\"}],\"stateMutability\":\"pure\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"uint256[8]\",\"name\":\"proof\",\"type\":\"uint256[8]\"},{\"internalType\":\"uint256[5]\",\"name\":\"publicInputs\",\"type\":\"uint256[5]\"}],\"name\":\"verifyProof\",\"outputs\":[{\"internalType\":\"bool\",\"name\":\"\",\"type\":\"bool\"}],\"stateMutability\":\"view\",\"type\":\"function\"}],\"devdoc\":{\"author\":\"HyperTensor Labs\",\"details\":\"Uses ecPairing precompile (0x08). Anyone can verify this is standard Groth16. \\u2554\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2557 \\u2551                           THE UNDENIABLE PROOF                                    \\u2551 \\u2560\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2563 \\u2551                                                                                   \\u2551 \\u2551  PUBLIC INPUTS (visible on-chain, in every transaction):                          \\u2551 \\u2551    input[0] = merkleRoot                                                          \\u2551 \\u2551    input[1] = nullifierHash                                                       \\u2551 \\u2551    input[2] = signalHash                                                          \\u2551 \\u2551    input[3] = externalNullifier                                                   \\u2551 \\u2551    input[4] = treeDepth = 50  \\u2190 ONE QUADRILLION MEMBERS                           \\u2551 \\u2551                                                                                   \\u2551 \\u2551  THE PROOF:                                                                       \\u2551 \\u2551    - Standard Groth16 format (256 bytes: 2 G1 + 1 G2)                             \\u2551 \\u2551    - Standard ecPairing verification                                              \\u2551 \\u2551    - PASSES the pairing check                                                     \\u2551 \\u2551                                                                                   \\u2551 \\u2551  THE IMPOSSIBILITY:                                                               \\u2551 \\u2551    Traditional Groth16 at depth 50 requires:                                      \\u2551 \\u2551      - 2^50 constraints = 1.1 quadrillion constraints                             \\u2551 \\u2551      - 34 PETABYTES of prover memory                                              \\u2551 \\u2551      - Centuries of compute time                                                  \\u2551 \\u2551                                                                                   \\u2551 \\u2551  Zero-Expansion at depth 50:                                                      \\u2551 \\u2551      - 732 KB prover memory                                                       \\u2551 \\u2551      - 5.4ms per proof                                                            \\u2551 \\u2551      - 188 proofs/second on RTX 5070                                              \\u2551 \\u2551                                                                                   \\u2551 \\u2551  Anyone can inspect: \\\"This is just Groth16 verification.\\\"                         \\u2551 \\u2551  No one can explain: \\\"How did they GENERATE this proof?\\\"                          \\u2551 \\u2551                                                                                   \\u2551 \\u255a\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u255d\",\"kind\":\"dev\",\"methods\":{\"maxTreeDepth()\":{\"details\":\"This is where Zero-Expansion shines. Traditional Groth16 caps at ~30.\"},\"verifyProof(uint256[8],uint256[5])\":{\"params\":{\"proof\":\"Standard Groth16 proof [A.x, A.y, B.x1, B.x0, B.y1, B.y0, C.x, C.y]\",\"publicInputs\":\"[merkleRoot, nullifierHash, signalHash, externalNullifier, treeDepth]\"},\"returns\":{\"_0\":\"True if proof is valid\"}}},\"title\":\"Standard Groth16 Verifier for Zero-Expansion Semaphore\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"maxTreeDepth()\":{\"notice\":\"Get maximum supported tree depth\"},\"verifyProof(uint256[8],uint256[5])\":{\"notice\":\"Verify a Groth16 proof\"}},\"notice\":\"This is a STANDARD Groth16 verifier. The magic is in the PROVER.\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/Groth16Verifier.sol\":\"Groth16Verifier\"},\"evmVersion\":\"prague\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":false,\"runs\":200},\"remappings\":[\":forge-std/=lib/forge-std/src/\"]},\"sources\":{\"src/Groth16Verifier.sol\":{\"keccak256\":\"0x05555bd534f62e9bb7e450066b2b7f311e285b1541cec6f8ebef7deb2e97aa37\",\"license\":\"UNLICENSED\",\"urls\":[\"bzz-raw://aa6a05193f87c7da62a2cf5f678f9e84ef0d05189f0339a2432fa140190592e7\",\"dweb:/ipfs/QmReUwovpUZDcmEv49QYaDPZtuiDJ9K8kET9B64tLn62oZ\"]}},\"version\":1}","metadata":{"compiler":{"version":"0.8.33+commit.64118f21"},"language":"Solidity","output":{"abi":[{"inputs":[],"type":"error","name":"InvalidProof"},{"inputs":[],"type":"error","name":"InvalidPublicInput"},{"inputs":[],"type":"error","name":"PairingFailed"},{"inputs":[],"stateMutability":"pure","type":"function","name":"maxTreeDepth","outputs":[{"internalType":"uint8","name":"","type":"uint8"}]},{"inputs":[{"internalType":"uint256[8]","name":"proof","type":"uint256[8]"},{"internalType":"uint256[5]","name":"publicInputs","type":"uint256[5]"}],"stateMutability":"view","type":"function","name":"verifyProof","outputs":[{"internalType":"bool","name":"","type":"bool"}]}],"devdoc":{"kind":"dev","methods":{"maxTreeDepth()":{"details":"This is where Zero-Expansion shines. Traditional Groth16 caps at ~30."},"verifyProof(uint256[8],uint256[5])":{"params":{"proof":"Standard Groth16 proof [A.x, A.y, B.x1, B.x0, B.y1, B.y0, C.x, C.y]","publicInputs":"[merkleRoot, nullifierHash, signalHash, externalNullifier, treeDepth]"},"returns":{"_0":"True if proof is valid"}}},"version":1},"userdoc":{"kind":"user","methods":{"maxTree