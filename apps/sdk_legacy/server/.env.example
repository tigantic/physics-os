# The Physics OS Server Environment Configuration
# Copy to .env and customize for your environment

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins for CORS
# Default: localhost only (secure default)
PHYSICS_OS_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# For development with all origins (NOT recommended for production):
# PHYSICS_OS_CORS_ORIGINS=*

# For production, specify exact origins:
# PHYSICS_OS_CORS_ORIGINS=https://myapp.example.com,https://api.example.com

# =============================================================================
# Server Configuration
# =============================================================================
# Host to bind the server to
# PHYSICS_OS_HOST=0.0.0.0

# Port to run the server on
# PHYSICS_OS_PORT=8000

# Number of worker processes (for uvicorn)
# PHYSICS_OS_WORKERS=4

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# PHYSICS_OS_LOG_LEVEL=INFO

# Log file path (optional, logs to stdout by default)
# PHYSICS_OS_LOG_FILE=/var/log/physics-os/server.log

# =============================================================================
# Security
# =============================================================================
# Secret key for signing (generate a strong random key for production)
# PHYSICS_OS_SECRET_KEY=your-secret-key-here

# API key for authentication (optional)
# PHYSICS_OS_API_KEY=your-api-key-here

# =============================================================================
# Performance
# =============================================================================
# Maximum field memory in bytes (default: 1GB)
# PHYSICS_OS_MAX_MEMORY=1073741824

# Maximum number of concurrent fields
# PHYSICS_OS_MAX_FIELDS=100

# Request timeout in seconds
# PHYSICS_OS_TIMEOUT=30
