      "default_config": {},
      "priority": 10
    },
    {
      "when": {
        "artifact_type": "table"
      },
      "component": "TableViewer",
      "default_config": {},
      "priority": 10
    }
  ],
  "templates": {
    "executive_summary_metric_ids": ["conservation_residual", "l2_drift", "mass", "momentum"],
    "publication_sections": ["Abstract", "Methods", "Results", "Integrity"],
