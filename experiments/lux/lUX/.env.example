# ──────────────────────────────── lUX Environment ────────────────────────────────
# Copy this file to .env.local and customize as needed.
# See docs/configuration.md for full documentation.

# ── Data Sources ────────────────────────────────────────────────────────────────

# Root directory containing proof-packages/ and domain-packs/ fixtures.
# Defaults to ../core/tests/fixtures relative to the UI package root.
LUX_FIXTURES_ROOT=

# Optional: Base URL for remote lUX API (uses HttpProvider instead of FilesystemProvider).
# When set, LUX_FIXTURES_ROOT is ignored.
# LUX_API_BASE_URL=

# ── Application ─────────────────────────────────────────────────────────────────

# Base URL for canonical/Open Graph tags.
# Default: http://localhost:3000
LUX_BASE_URL=

# Optional: how long (in seconds) to cache gallery pages via ISR.
# Default: 0 (no cache, re-render each request). Set to 3600 for 1-hour cache.
LUX_REVALIDATE=0

# ── Authentication ──────────────────────────────────────────────────────────────
# Auth is DISABLED by default. Set LUX_API_KEY to enable.

# API key required for access. Clients must send: Authorization: Bearer <key>
# Leave empty or unset for public (unauthenticated) access.
# LUX_API_KEY=

# JSON map of API keys to roles: { "<key>": "admin" | "auditor" | "viewer" }
# Keys not in this map get the default role: "viewer".
# LUX_AUTH_ROLES=

# ── Observability ───────────────────────────────────────────────────────────────

# Minimum log level: debug | info | warn | error
# Default: info
LUX_LOG_LEVEL=info

# Optional: endpoint for Web Vitals reporting.
# Set to /api/errors or a custom analytics endpoint to collect TTFB/FCP/LCP/CLS/INP.
# NEXT_PUBLIC_LUX_VITALS_ENDPOINT=

# ── Sentry (optional — behind flag for OSS builds) ─────────────────────────────
# When configured, source maps are uploaded to Sentry in CI and errors are
# deobfuscated in the Sentry dashboard. Leave all unset to disable.

# Client-side DSN for error reporting (public, safe to expose)
# NEXT_PUBLIC_SENTRY_DSN=

# Sentry organization slug (used by CI source map upload)
# SENTRY_ORG=

# Sentry project slug (used by CI source map upload)
# SENTRY_PROJECT=

# Auth token with project:releases and org:read scopes (secret — only in CI)
# SENTRY_AUTH_TOKEN=

# ── Build Metadata (injected by CI / Docker) ───────────────────────────────────

# Application version (git tag or semver). Shown in /api/health response.
# LUX_VERSION=dev

# Git commit SHA. Shown in /api/health response.
# LUX_COMMIT_SHA=unknown

# ── Development ─────────────────────────────────────────────────────────────────

# Set to "true" in CI environments.
CI=

# Set to "true" to enable bundle analysis during build.
# ANALYZE=
