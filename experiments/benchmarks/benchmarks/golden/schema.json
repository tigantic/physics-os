{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tigantic/physics-os/benchmarks/golden/schema.json",
  "title": "Golden Physics Benchmark Measurement",
  "description": "Schema for a single golden benchmark measurement across the 7 QTT physics domains.",
  "type": "object",
  "required": [
    "domain",
    "trial",
    "seed",
    "n_bits",
    "n_steps",
    "max_rank",
    "n_dims",
    "grid_points",
    "wall_time_s",
    "throughput_gp_per_s",
    "conservation_quantity",
    "conservation_initial",
    "conservation_final",
    "conservation_relative_error",
    "conservation_status",
    "conservation_within_band",
    "conservation_band_max",
    "certificate_issued",
    "certificate_verified",
    "certificate_job_id",
    "n_claims",
    "pipeline_success",
    "device",
    "timestamp"
  ],
  "properties": {
    "domain": {
      "type": "string",
      "description": "Physics domain key.",
      "enum": [
        "burgers",
        "maxwell",
        "maxwell_3d",
        "schrodinger",
        "advection_diffusion",
        "vlasov_poisson",
        "navier_stokes_2d"
      ]
    },
    "trial": {
      "type": "integer",
      "description": "Trial number (1-indexed).",
      "minimum": 1
    },
    "seed": {
      "type": "integer",
      "description": "Random seed used for this trial."
    },
    "n_bits": {
      "type": "integer",
      "description": "QTT resolution: bits per spatial axis.",
      "minimum": 2,
      "maximum": 20
    },
    "n_steps": {
      "type": "integer",
      "description": "Number of time-integration steps.",
      "minimum": 1
    },
    "max_rank": {
      "type": "integer",
      "description": "Maximum bond dimension / rank truncation ceiling.",
      "minimum": 1
    },
    "n_dims": {
      "type": "integer",
      "description": "Number of spatial dimensions.",
      "minimum": 1,
      "maximum": 6
    },
    "grid_points": {
      "type": "integer",
      "description": "Total grid cells = product of per-axis resolutions.",
      "minimum": 1
    },
    "wall_time_s": {
      "type": "number",
      "description": "Wall clock execution time in seconds.",
      "minimum": 0
    },
    "throughput_gp_per_s": {
      "type": "number",
      "description": "Throughput: grid_points × n_steps / wall_time_s.",
      "minimum": 0
    },
    "conservation_quantity": {
      "type": "string",
      "description": "Name of the conserved physical invariant.",
      "minLength": 1
    },
    "conservation_initial": {
      "type": ["number", "null"],
      "description": "Invariant value at t=0."
    },
    "conservation_final": {
      "type": ["number", "null"],
      "description": "Invariant value at t=T."
    },
    "conservation_relative_error": {
      "type": "number",
      "description": "Relative invariant violation: |I(T) - I(0)| / |I(0)|.",
      "minimum": 0
    },
    "conservation_status": {
      "type": "string",
      "description": "Conservation classification.",
      "enum": ["conserved", "drift"]
    },
    "conservation_within_band": {
      "type": "boolean",
      "description": "Whether conservation_relative_error <= conservation_band_max."
    },
    "conservation_band_max": {
      "type": "number",
      "description": "Documented maximum conservation error for this domain.",
      "minimum": 0
    },
    "certificate_issued": {
      "type": "boolean",
      "description": "Whether a certificate was successfully issued."
    },
    "certificate_verified": {
      "type": "boolean",
      "description": "Whether the certificate signature verified."
    },
    "certificate_job_id": {
      "type": "string",
      "description": "Job ID embedded in the certificate.",
      "minLength": 1
    },
    "n_claims": {
      "type": "integer",
      "description": "Number of claims generated by the evidence pipeline.",
      "minimum": 0
    },
    "pipeline_success": {
      "type": "boolean",
      "description": "Whether the full pipeline completed without error."
    },
    "device": {
      "type": "string",
      "description": "Compute device used.",
      "enum": ["cpu", "cuda", "gpu"]
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of measurement.",
      "format": "date-time"
    },
    "conservation_drift_per_step": {
      "type": "number",
      "description": "conservation_relative_error / n_steps.",
      "minimum": 0
    },
    "fields_returned": {
      "type": "array",
      "description": "Names of physical fields in the sanitized output.",
      "items": { "type": "string" }
    },
    "grid_resolution": {
      "type": "array",
      "description": "Per-axis resolution array.",
      "items": { "type": "integer", "minimum": 1 }
    },
    "domain_bounds": {
      "type": "array",
      "description": "Spatial domain bounds [[lo, hi], ...].",
      "items": {
        "type": "array",
        "items": { "type": "number" },
        "minItems": 2,
        "maxItems": 2
      }
    },
    "wall_time_band_max": {
      "type": "number",
      "description": "Maximum allowed wall time for this domain.",
      "minimum": 0
    },
    "runtime_version": {
      "type": "string",
      "description": "tensornet.vm runtime version string."
    },
    "error_message": {
      "type": "string",
      "description": "Error details if pipeline_success is false."
    }
  },
  "additionalProperties": false
}
