{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tigantic/physics-os/benchmarks/rank_atlas/schema.json",
  "title": "Rank Atlas Measurement",
  "description": "Schema for a single QTT bond-dimension measurement in the Rank Atlas Benchmark v1.0.",
  "type": "object",
  "required": [
    "pack_id",
    "domain_name",
    "problem_name",
    "n_bits",
    "n_cells",
    "complexity_param_name",
    "complexity_param_value",
    "svd_tolerance",
    "max_rank_ceiling",
    "n_sites",
    "bond_dimensions",
    "singular_value_spectra",
    "max_rank",
    "mean_rank",
    "median_rank",
    "rank_std",
    "peak_rank_site",
    "rank_utilization",
    "dense_bytes",
    "qtt_bytes",
    "compression_ratio",
    "wall_time_s",
    "peak_gpu_mem_mb",
    "device",
    "timestamp",
    "seed"
  ],
  "properties": {
    "pack_id": {
      "type": "string",
      "description": "Pack identifier (Roman numeral I–XX).",
      "pattern": "^(I{1,3}|IV|V|VI{0,3}|IX|X{1,3}|XI{0,3}|XIV|XV|XVI{0,3}|XIX|XX)$"
    },
    "domain_name": {
      "type": "string",
      "description": "Physics domain name.",
      "minLength": 1
    },
    "problem_name": {
      "type": "string",
      "description": "Specific problem within the pack.",
      "minLength": 1
    },
    "n_bits": {
      "type": "integer",
      "description": "Number of binary digits per axis (N = 2^n_bits grid points per axis).",
      "minimum": 4,
      "maximum": 20
    },
    "n_cells": {
      "type": "integer",
      "description": "Total grid cells = (2^n_bits)^d.",
      "minimum": 1
    },
    "complexity_param_name": {
      "type": "string",
      "description": "Name of the complexity parameter being swept, or 'fixed' for V0.2 packs.",
      "minLength": 1
    },
    "complexity_param_value": {
      "type": "number",
      "description": "Value of the complexity parameter."
    },
    "svd_tolerance": {
      "type": "number",
      "description": "SVD truncation tolerance (relative).",
      "exclusiveMinimum": 0,
      "maximum": 1
    },
    "max_rank_ceiling": {
      "type": "integer",
      "description": "Maximum allowed bond dimension. Must be >= 2048 for benchmark compliance.",
      "minimum": 1
    },
    "n_sites": {
      "type": "integer",
      "description": "Number of QTT sites = d * n_bits.",
      "minimum": 1
    },
    "bond_dimensions": {
      "type": "array",
      "description": "Bond dimension at each of n_sites - 1 bonds.",
      "items": {
        "type": "integer",
        "minimum": 1
      },
      "minItems": 1
    },
    "singular_value_spectra": {
      "type": "array",
      "description": "Full singular value spectrum at each bond. Outer array has n_sites - 1 elements.",
      "items": {
        "type": "array",
        "items": {
          "type": "number",
          "minimum": 0
        },
        "minItems": 1
      },
      "minItems": 1
    },
    "max_rank": {
      "type": "integer",
      "description": "Maximum bond dimension across all sites.",
      "minimum": 1
    },
    "mean_rank": {
      "type": "number",
      "description": "Mean bond dimension across all sites.",
      "minimum": 0
    },
    "median_rank": {
      "type": "integer",
      "description": "Median bond dimension across all sites.",
      "minimum": 1
    },
    "rank_std": {
      "type": "number",
      "description": "Standard deviation of bond dimensions.",
      "minimum": 0
    },
    "peak_rank_site": {
      "type": "integer",
      "description": "Site index where maximum rank occurs.",
      "minimum": 0
    },
    "rank_utilization": {
      "type": "number",
      "description": "mean_rank / max_rank.",
      "minimum": 0,
      "maximum": 1
    },
    "dense_bytes": {
      "type": "integer",
      "description": "Dense storage in bytes.",
      "minimum": 1
    },
    "qtt_bytes": {
      "type": "integer",
      "description": "QTT storage in bytes.",
      "minimum": 1
    },
    "compression_ratio": {
      "type": "number",
      "description": "dense_bytes / qtt_bytes. Values > 1 indicate compression.",
      "exclusiveMinimum": 0
    },
    "wall_time_s": {
      "type": "number",
      "description": "Wall clock time in seconds.",
      "minimum": 0
    },
    "peak_gpu_mem_mb": {
      "type": "number",
      "description": "Peak GPU memory usage in MB. 0 if CPU-only.",
      "minimum": 0
    },
    "device": {
      "type": "string",
      "description": "Compute device used.",
      "enum": ["cuda", "cpu"]
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of measurement.",
      "format": "date-time"
    },
    "seed": {
      "type": "integer",
      "description": "Random seed used for reproducibility."
    },
    "sv_decay_exponents": {
      "type": "array",
      "description": "Per-bond singular value decay fit exponent.",
      "items": { "type": "number" }
    },
    "sv_decay_mean": {
      "type": "number",
      "description": "Mean SV decay exponent across bonds."
    },
    "spectral_gaps": {
      "type": "array",
      "description": "Spectral gap sigma_1/sigma_2 at each bond.",
      "items": { "type": "number", "minimum": 0 }
    },
    "bond_entropies": {
      "type": "array",
      "description": "Von Neumann entanglement entropy at each bond.",
      "items": { "type": "number", "minimum": 0 }
    },
    "total_entropy": {
      "type": "number",
      "description": "Sum of bond entropies.",
      "minimum": 0
    },
    "entropy_density": {
      "type": "number",
      "description": "total_entropy / n_sites.",
      "minimum": 0
    },
    "effective_ranks": {
      "type": "array",
      "description": "Effective rank e^{S_k} at each bond.",
      "items": { "type": "number", "minimum": 0 }
    },
    "area_law_exponent": {
      "type": "number",
      "description": "Entanglement scaling fit exponent."
    },
    "area_law_r_squared": {
      "type": "number",
      "description": "Fit quality for area law scaling.",
      "minimum": 0,
      "maximum": 1
    },
    "area_law_type": {
      "type": "string",
      "description": "Classification of entanglement scaling.",
      "enum": ["area", "volume", "log_corrected"]
    },
    "reconstruction_error": {
      "type": "number",
      "description": "Relative reconstruction error ||u_QTT - u_ref|| / ||u_ref||.",
      "minimum": 0
    },
    "physics_invariant_name": {
      "type": "string",
      "description": "Name of the conserved physical quantity."
    },
    "physics_invariant_value": {
      "type": "number",
      "description": "Relative invariant violation |I(T) - I(0)| / I(0).",
      "minimum": 0
    },
    "physics_invariant_passed": {
      "type": "boolean",
      "description": "Whether the invariant conservation test passed."
    }
  },
  "additionalProperties": false
}
