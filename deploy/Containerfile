# FluidElite V1 - Gevulot Firestarter Container
# ================================================
#
# This builds a minimal container for the Gevulot VM.
# The binary must be statically linked (musl).
#
# Build with:
#   podman build -t localhost/fluidelite-v1:latest .
#
# Then package for Gevulot:
#   gvltctl build --container containers-storage:localhost/fluidelite-v1:latest -o fluidelite.img

# Start from scratch - our binary is fully static
FROM scratch

# The statically linked Rust prover binary
# Built with: cargo build --release --features halo2 --target x86_64-unknown-linux-musl --bin gevulot-prover
COPY target/x86_64-unknown-linux-musl/release/gevulot-prover /program

# The hybrid model weights (65.8 MB)
COPY crates/fluidelite/data/fluidelite_hybrid.bin /fluidelite_v1.bin

# Gevulot Firestarter entrypoint
ENTRYPOINT ["/program"]
