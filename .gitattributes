# Git LFS Tracking Rules
# ======================
# Large binary files that should be managed via Git LFS.
# To activate: git lfs install && git lfs migrate import --include="<patterns>"
#
# After migration, new pushes of these patterns are automatically handled by LFS.
# Existing objects in history require `git lfs migrate import` to convert.

# ── Compiled binaries ─────────────────────────────────────────────────
products/fluidelite-zk/gvltctl filter=lfs diff=lfs merge=lfs -text

# ── Large data files ──────────────────────────────────────────────────
data/holy_grail_5d.gif filter=lfs diff=lfs merge=lfs -text
data/wikitext2_train.txt filter=lfs diff=lfs merge=lfs -text
data/HVAC_Blueprint.png filter=lfs diff=lfs merge=lfs -text

# ── Documentation artifacts ───────────────────────────────────────────
docs/api/tensornet/cfd.tar filter=lfs diff=lfs merge=lfs -text

# ── Generic thresholds for future files ───────────────────────────────
*.bin filter=lfs diff=lfs merge=lfs -text
*.img filter=lfs diff=lfs merge=lfs -text
*.tar filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text
*.whl filter=lfs diff=lfs merge=lfs -text
*.obj filter=lfs diff=lfs merge=lfs -text
