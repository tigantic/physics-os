{
    "FileVersion": 3,
    "Version": 1,
    "VersionName": "1.0.0",
    "FriendlyName": "Ontic",
    "Description": "QTT-compressed field visualization and simulation for Unreal Engine",
    "Category": "Simulation",
    "CreatedBy": "Tigantic Labs",
    "CreatedByURL": "https://github.com/tigantic/Ontic",
    "DocsURL": "https://github.com/tigantic/Ontic/tree/main/integrations/unreal",
    "MarketplaceURL": "",
    "SupportURL": "https://github.com/tigantic/Ontic/issues",
    "CanContainContent": true,
    "IsBetaVersion": true,
    "IsExperimentalVersion": false,
    "Installed": false,
    "Modules": [
        {
            "Name": "Ontic",
            "Type": "Runtime",
            "LoadingPhase": "Default",
            "PlatformAllowList": [
                "Win64",
                "Linux"
            ]
        }
    ],
    "Plugins": [
        {
            "Name": "ProceduralMeshComponent",
            "Enabled": true
        },
        {
            "Name": "Niagara",
            "Enabled": true
        }
    ]
}
